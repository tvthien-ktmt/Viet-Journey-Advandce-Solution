# Database Configuration
DATABASE_URL="mysql://root:password@localhost:3306/vietjourney"

# Security
JWT_SECRET="your_super_secret_key"
JWT_EXPIRATION_MS=86400000


# VNPay Payment Gateway
VNP_TMN_CODE="YOUR_TMN_CODE"
VNP_HASH_SECRET="YOUR_HASH_SECRET"
VNP_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNP_RETURN_URL="http://localhost:5173/payment-return"

# SePay Configuration
SEPAY_API_URL=https://my.sepay.vn/userapi
SEPAY_ACCOUNT_NUMBER=YOUR_SEPAY_ACCOUNT_NO
SEPAY_ACCOUNT_NAME=YOUR_SEPAY_ACCOUNT_NAME
SEPAY_BANK_CODE=YOUR_SEPAY_BANK_CODE
SEPAY_API_KEY=YOUR_SEPAY_API_KEY
SEPAY_TEMPLATE=compact2

# Payment Configuration
PAYMENT_TIMEOUT=300000
PAYMENT_CHECK_INTERVAL=3000
